generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  active
  archived
}

enum ChapterStatus {
  planned
  drafted
  reviewed
}

enum JobStatus {
  queued
  running
  completed
  failed
}

enum ValidationSeverity {
  error
  warning
  info
}

model Project {
  id                    String           @id @default(uuid()) @db.Uuid
  ownerId               String?          @db.Uuid
  title                 String           @db.VarChar(255)
  genre                 String?          @db.Text
  theme                 String?          @db.Text
  tone                  String?          @db.Text
  logline               String?
  synopsis              String?
  outline               String?
  targetWordCount       Int?
  status                ProjectStatus    @default(draft)
  defaultStyleProfileId String?          @db.Uuid
  defaultModelProfileId String?          @db.Uuid
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  characters            Character[]
  lorebookEntries       LorebookEntry[]
  chapters              Chapter[]
  volumes               Volume[]
  memoryChunks          MemoryChunk[]
  storyEvents           StoryEvent[]
  characterStateSnapshots CharacterStateSnapshot[]
  foreshadowTracks      ForeshadowTrack[]
  validationIssues      ValidationIssue[]
  generationJobs        GenerationJob[]
  styleProfiles         StyleProfile[]
  modelProfiles         ModelProfile[]
  promptTemplates       PromptTemplate[]
  guidedSession         GuidedSession?
  agentRuns             AgentRun[]
}

model AgentRun {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  chapterId   String?  @db.Uuid
  agentType   String   @db.VarChar(80)
  taskType    String?  @db.VarChar(80)
  status      String   @db.VarChar(50)
  mode        String   @db.VarChar(20)
  goal        String
  input       Json     @default("{}")
  output      Json?
  error       String?
  policy      Json?
  createdBy   String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plans       AgentPlan[]
  steps       AgentStep[]
  artifacts   AgentArtifact[]
  approvals   AgentApproval[]

  @@index([projectId, status, createdAt])
}

model AgentPlan {
  id                String   @id @default(uuid()) @db.Uuid
  agentRunId         String   @db.Uuid
  version            Int      @default(1)
  status             String   @db.VarChar(50)
  taskType           String   @db.VarChar(80)
  summary            String
  assumptions        Json?
  risks              Json?
  steps              Json
  requiredApprovals  Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  agentRun           AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, version])
}

model AgentStep {
  id          String   @id @default(uuid()) @db.Uuid
  agentRunId  String   @db.Uuid
  planVersion Int      @default(1)
  stepNo      Int
  stepType    String   @db.VarChar(50)
  name        String   @db.VarChar(255)
  toolName    String?  @db.VarChar(100)
  status      String   @db.VarChar(50)
  mode        String   @db.VarChar(20)
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())

  agentRun    AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@unique([agentRunId, mode, planVersion, stepNo])
  @@index([agentRunId, planVersion, mode])
}

model AgentArtifact {
  id            String   @id @default(uuid()) @db.Uuid
  agentRunId    String   @db.Uuid
  artifactType  String   @db.VarChar(100)
  title         String   @db.VarChar(255)
  content       Json
  status        String   @db.VarChar(50)
  sourceStepNo  Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentRun      AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, artifactType])
}

model AgentApproval {
  id            String   @id @default(uuid()) @db.Uuid
  agentRunId    String   @db.Uuid
  approvalType  String   @db.VarChar(80)
  status        String   @db.VarChar(50)
  target        Json
  approvedBy    String?  @db.Uuid
  approvedAt    DateTime?
  comment       String?
  createdAt     DateTime @default(now())

  agentRun      AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, status])
}

model StyleProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  projectId          String   @db.Uuid
  name               String   @db.VarChar(100)
  pov                String?  @db.Text
  tense              String?  @db.Text
  proseStyle         String?  @db.Text
  pacing             String?  @db.Text
  dialogueDensity    Int      @default(50)
  narrationDensity   Int      @default(50)
  descriptionDensity Int      @default(50)
  darknessLevel      Int      @default(50)
  humorLevel         Int      @default(10)
  emotionalIntensity Int      @default(50)
  sentenceStyle      Json     @default("{}")
  forbiddenPatterns  Json     @default("[]")
  preferredPatterns  Json     @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ModelProfile {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @db.Uuid
  name              String   @db.VarChar(100)
  plannerProvider   String?  @db.VarChar(50)
  plannerModel      String?  @db.VarChar(100)
  writerProvider    String?  @db.VarChar(50)
  writerModel       String?  @db.VarChar(100)
  summarizerProvider String? @db.VarChar(50)
  summarizerModel   String?  @db.VarChar(100)
  validatorProvider String?  @db.VarChar(50)
  validatorModel    String?  @db.VarChar(100)
  embeddingProvider String?  @db.VarChar(50)
  embeddingModel    String?  @db.VarChar(100)
  writerParams      Json     @default("{}")
  plannerParams     Json     @default("{}")
  summarizerParams  Json     @default("{}")
  validatorParams   Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Character {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @db.Uuid
  name              String   @db.VarChar(100)
  alias             Json     @default("[]")
  roleType          String?  @db.VarChar(50)
  personalityCore   String?
  motivation        String?
  speechStyle       String?
  backstory         String?
  growthArc         String?
  isDead            Boolean  @default(false)
  scope             String?  @db.VarChar(20)   // "global" | "volume" | "chapter"
  activeFromChapter Int?                        // first appearance chapter number
  activeToChapter   Int?                        // last appearance chapter number (null = still active)
  source            String   @default("manual") @db.VarChar(30) // "manual" | "guided" | "auto_extracted"
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, name])
}

model LorebookEntry {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @db.Uuid
  title            String   @db.VarChar(255)
  entryType        String   @db.VarChar(50)
  content          String
  summary          String?
  tags             Json     @default("[]")
  priority         Int      @default(50)
  triggerKeywords  Json     @default("[]")
  relatedEntityIds Json     @default("[]")
  status           String   @default("active") @db.VarChar(50)
  sourceType       String   @default("manual") @db.VarChar(50)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, entryType])
}

model Chapter {
  id                String           @id @default(uuid()) @db.Uuid
  projectId         String           @db.Uuid
  volumeId          String?          @db.Uuid
  chapterNo         Int
  title             String?          @db.VarChar(255)
  objective         String?
  conflict          String?
  revealPoints      String?
  foreshadowPlan    String?
  outline           String?
  status            ChapterStatus    @default(planned)
  expectedWordCount Int?
  actualWordCount   Int?
  timelineSeq       Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  volume            Volume?          @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  drafts            ChapterDraft[]
  storyEvents       StoryEvent[]
  characterStateSnapshots CharacterStateSnapshot[]
  foreshadowTracks  ForeshadowTrack[]
  validationIssues  ValidationIssue[]
  generationJobs    GenerationJob[]

  @@unique([projectId, chapterNo])
}

model ChapterDraft {
  id                String   @id @default(uuid()) @db.Uuid
  chapterId         String   @db.Uuid
  versionNo         Int
  content           String
  source            String   @db.VarChar(50)
  modelInfo         Json     @default("{}")
  generationContext Json     @default("{}")
  isCurrent         Boolean  @default(false)
  createdBy         String?  @db.Uuid
  createdAt         DateTime @default(now())
  chapter           Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, versionNo])
}

model MemoryChunk {
  id              String                @id @default(uuid()) @db.Uuid
  projectId       String                @db.Uuid
  sourceType      String                @db.VarChar(50)
  sourceId        String                @db.Uuid
  memoryType      String                @db.VarChar(50)
  content         String
  summary         String?
  embedding       Json?
  embeddingVector Unsupported("vector")?
  tags            Json                  @default("[]")
  sourceTrace     Json                  @default("{}")
  metadata        Json                  @default("{}")
  importanceScore Int                   @default(50)
  freshnessScore  Int                   @default(50)
  recencyScore    Int                   @default(50)
  status          String                @default("auto") @db.VarChar(50)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, memoryType, status])
  @@index([projectId, sourceType, sourceId])
}

model StoryEvent {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  chapterId   String   @db.Uuid
  chapterNo   Int?
  sourceDraftId String? @db.Uuid
  title       String   @db.VarChar(255)
  eventType   String   @db.VarChar(50)
  description String
  participants Json    @default("[]")
  timelineSeq  Int?
  status      String   @default("detected") @db.VarChar(50)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId, chapterNo])
  @@index([projectId, eventType])
}

model CharacterStateSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  chapterId    String   @db.Uuid
  chapterNo    Int?
  sourceDraftId String? @db.Uuid
  characterId  String?  @db.Uuid
  characterName String  @db.VarChar(100)
  stateType    String   @db.VarChar(50)
  stateValue   String
  summary      String?
  status       String   @default("auto") @db.VarChar(50)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter      Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId, characterName, chapterNo])
  @@index([projectId, status])
}

model ForeshadowTrack {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @db.Uuid
  chapterId        String?  @db.Uuid
  chapterNo        Int?
  sourceDraftId    String?  @db.Uuid
  title            String   @db.VarChar(255)
  detail           String?
  status           String   @default("planned") @db.VarChar(50)
  scope            String   @default("chapter") @db.VarChar(20) // "arc" | "volume" | "chapter"
  source           String   @default("manual") @db.VarChar(30)  // "guided" | "auto_extracted" | "manual"
  firstSeenChapterNo Int?
  lastSeenChapterNo  Int?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter          Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId, title])
  @@index([projectId, status])
}


model ValidationIssue {
  id          String              @id @default(uuid()) @db.Uuid
  projectId   String              @db.Uuid
  chapterId   String?             @db.Uuid
  issueType   String              @db.VarChar(100)
  severity    ValidationSeverity
  entityType  String?             @db.VarChar(50)
  entityId    String?             @db.Uuid
  message     String
  evidence    Json                @default("[]")
  suggestion  String?
  status      String              @default("open") @db.VarChar(50)
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter     Chapter?            @relation(fields: [chapterId], references: [id], onDelete: SetNull)
}

model GenerationJob {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @db.Uuid
  chapterId        String?   @db.Uuid
  jobType          String    @db.VarChar(50)
  targetType       String    @db.VarChar(50)
  targetId         String    @db.Uuid
  status           JobStatus @default(queued)
  requestPayload   Json      @default("{}")
  responsePayload  Json      @default("{}")
  retrievalPayload Json      @default("{}")
  promptSnapshot   String?
  errorMessage     String?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime  @default(now())
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter          Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)
}

model Volume {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  volumeNo     Int
  title        String?  @db.VarChar(255)
  synopsis     String?
  objective    String?
  chapterCount Int?
  status       String   @default("planned") @db.VarChar(50)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapters     Chapter[]

  @@unique([projectId, volumeNo])
}

model PromptTemplate {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String?  @db.Uuid
  stepKey       String   @db.VarChar(50)
  name          String   @db.VarChar(100)
  description   String?
  systemPrompt  String
  userTemplate  String
  version       Int      @default(1)
  isDefault     Boolean  @default(false)
  tags          Json     @default("[]")
  effectPreview String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stepKey, name])
  @@index([stepKey, isDefault])
}

model GuidedSession {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  currentStep String   @db.VarChar(50)
  stepData    Json     @default("{}")
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId])
}

/// LLM 服务提供商配置（当前仅支持 OpenAI-Compatible 格式）
/// providerType 字段预留，未来可扩展 Claude/Gemini 等
model LlmProvider {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @db.VarChar(100)                        // 显示名称，如 "GPT-5.4 主力"
  providerType  String        @default("openai_compatible") @db.VarChar(50)
  baseUrl       String        @db.VarChar(500)                        // API base URL (e.g. https://api.openai.com/v1)
  apiKey        String        @db.Text                                // API Key（明文存储，与 .env 同级安全）
  defaultModel  String        @db.VarChar(200)                        // 默认模型名 (e.g. gpt-4o)
  extraConfig   Json          @default("{}")                          // 扩展配置（默认 temperature 等）
  isDefault     Boolean       @default(false)                         // 默认 Provider：步骤未配置路由时使用
  isActive      Boolean       @default(true)                          // 软停用标记
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  routings      LlmRouting[]
}

/// 应用步骤 → LLM Provider 路由映射
/// 固定 3 个步骤：guided（创作引导）、generate（章节生成）、polish（章节润色）
/// validation/fact_extractor/summary 等内部服务不走路由，直接用默认 Provider
model LlmRouting {
  id             String       @id @default(uuid()) @db.Uuid
  appStep        String       @unique @db.VarChar(50)                 // "guided" | "generate" | "polish"
  providerId     String       @db.Uuid
  modelOverride  String?      @db.VarChar(200)                        // 可选：覆盖 provider 的默认模型
  paramsOverride Json         @default("{}")                          // 可选：覆盖 temperature/maxTokens 等
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  provider       LlmProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
}
