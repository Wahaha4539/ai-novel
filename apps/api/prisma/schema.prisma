generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  active
  archived
}

enum ChapterStatus {
  planned
  drafted
  reviewed
}

enum JobStatus {
  queued
  running
  completed
  failed
}

enum ValidationSeverity {
  error
  warning
  info
}

model Project {
  id                    String           @id @default(uuid()) @db.Uuid
  ownerId               String?          @db.Uuid
  title                 String           @db.VarChar(255)
  genre                 String?          @db.Text
  theme                 String?          @db.Text
  tone                  String?          @db.Text
  logline               String?
  synopsis              String?
  outline               String?
  targetWordCount       Int?
  status                ProjectStatus    @default(draft)
  defaultStyleProfileId String?          @db.Uuid
  defaultModelProfileId String?          @db.Uuid
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  characters            Character[]
  lorebookEntries       LorebookEntry[]
  chapters              Chapter[]
  volumes               Volume[]
  memoryChunks          MemoryChunk[]
  storyEvents           StoryEvent[]
  characterStateSnapshots CharacterStateSnapshot[]
  foreshadowTracks      ForeshadowTrack[]
  writingRules          WritingRule[]
  relationshipEdges     RelationshipEdge[]
  timelineEvents        TimelineEvent[]
  sceneCards            SceneCard[]
  chapterPatterns       ChapterPattern[]
  pacingBeats           PacingBeat[]
  validationIssues      ValidationIssue[]
  qualityReports        QualityReport[]
  generationJobs        GenerationJob[]
  styleProfiles         StyleProfile[]
  modelProfiles         ModelProfile[]
  creativeProfile       ProjectCreativeProfile?
  generationProfile     GenerationProfile?
  promptTemplates       PromptTemplate[]
  guidedSession         GuidedSession?
  agentRuns             AgentRun[]
}

model ProjectCreativeProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  projectId          String   @unique @db.Uuid
  audienceType       String?  @db.VarChar(80)
  platformTarget     String?  @db.VarChar(80)
  sellingPoints      Json     @default("[]")
  pacingPreference   String?  @db.VarChar(80)
  targetWordCount    Int?
  chapterWordCount   Int?
  contentRating      String?  @db.VarChar(80)
  centralConflict    Json     @default("{}")
  generationDefaults Json     @default("{}")
  validationDefaults Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model GenerationProfile {
  id                       String   @id @default(uuid()) @db.Uuid
  projectId                String   @unique @db.Uuid
  defaultChapterWordCount  Int?
  autoContinue             Boolean  @default(false)
  autoSummarize            Boolean  @default(true)
  autoUpdateCharacterState Boolean  @default(true)
  autoUpdateTimeline       Boolean  @default(false)
  autoValidation           Boolean  @default(true)
  allowNewCharacters       Boolean  @default(false)
  allowNewLocations        Boolean  @default(true)
  allowNewForeshadows      Boolean  @default(true)
  preGenerationChecks      Json     @default("[]")
  promptBudget             Json     @default("{}")
  metadata                 Json     @default("{}")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AgentRun {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  chapterId   String?  @db.Uuid
  agentType   String   @db.VarChar(80)
  taskType    String?  @db.VarChar(80)
  status      String   @db.VarChar(50)
  mode        String   @db.VarChar(20)
  goal        String
  input       Json     @default("{}")
  output      Json?
  error       String?
  policy      Json?
  createdBy   String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plans       AgentPlan[]
  steps       AgentStep[]
  artifacts   AgentArtifact[]
  approvals   AgentApproval[]
  qualityReports QualityReport[]

  @@index([projectId, status, createdAt])
}

model AgentPlan {
  id                String   @id @default(uuid()) @db.Uuid
  agentRunId         String   @db.Uuid
  version            Int      @default(1)
  status             String   @db.VarChar(50)
  taskType           String   @db.VarChar(80)
  summary            String
  assumptions        Json?
  risks              Json?
  steps              Json
  requiredApprovals  Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  agentRun           AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, version])
}

model AgentStep {
  id          String   @id @default(uuid()) @db.Uuid
  agentRunId  String   @db.Uuid
  planVersion Int      @default(1)
  stepNo      Int
  stepType    String   @db.VarChar(50)
  name        String   @db.VarChar(255)
  toolName    String?  @db.VarChar(100)
  status      String   @db.VarChar(50)
  mode        String   @db.VarChar(20)
  input       Json?
  output      Json?
  metadata    Json     @default("{}")
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())

  agentRun    AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@unique([agentRunId, mode, planVersion, stepNo])
  @@index([agentRunId, planVersion, mode])
}

model AgentArtifact {
  id            String   @id @default(uuid()) @db.Uuid
  agentRunId    String   @db.Uuid
  artifactType  String   @db.VarChar(100)
  title         String   @db.VarChar(255)
  content       Json
  status        String   @db.VarChar(50)
  sourceStepNo  Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentRun      AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, artifactType])
}

model AgentApproval {
  id            String   @id @default(uuid()) @db.Uuid
  agentRunId    String   @db.Uuid
  approvalType  String   @db.VarChar(80)
  status        String   @db.VarChar(50)
  target        Json
  approvedBy    String?  @db.Uuid
  approvedAt    DateTime?
  comment       String?
  createdAt     DateTime @default(now())

  agentRun      AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, status])
}

model StyleProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  projectId          String   @db.Uuid
  name               String   @db.VarChar(100)
  pov                String?  @db.Text
  tense              String?  @db.Text
  proseStyle         String?  @db.Text
  pacing             String?  @db.Text
  dialogueDensity    Int      @default(50)
  narrationDensity   Int      @default(50)
  descriptionDensity Int      @default(50)
  darknessLevel      Int      @default(50)
  humorLevel         Int      @default(10)
  emotionalIntensity Int      @default(50)
  sentenceStyle      Json     @default("{}")
  forbiddenPatterns  Json     @default("[]")
  preferredPatterns  Json     @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ModelProfile {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @db.Uuid
  name              String   @db.VarChar(100)
  plannerProvider   String?  @db.VarChar(50)
  plannerModel      String?  @db.VarChar(100)
  writerProvider    String?  @db.VarChar(50)
  writerModel       String?  @db.VarChar(100)
  summarizerProvider String? @db.VarChar(50)
  summarizerModel   String?  @db.VarChar(100)
  validatorProvider String?  @db.VarChar(50)
  validatorModel    String?  @db.VarChar(100)
  embeddingProvider String?  @db.VarChar(50)
  embeddingModel    String?  @db.VarChar(100)
  writerParams      Json     @default("{}")
  plannerParams     Json     @default("{}")
  summarizerParams  Json     @default("{}")
  validatorParams   Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Character {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @db.Uuid
  name              String   @db.VarChar(100)
  alias             Json     @default("[]")
  roleType          String?  @db.VarChar(50)
  personalityCore   String?
  motivation        String?
  speechStyle       String?
  backstory         String?
  growthArc         String?
  isDead            Boolean  @default(false)
  scope             String?  @db.VarChar(20)   // "global" | "volume" | "chapter"
  activeFromChapter Int?                        // first appearance chapter number
  activeToChapter   Int?                        // last appearance chapter number (null = still active)
  source            String   @default("manual") @db.VarChar(30) // "manual" | "guided" | "auto_extracted"
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  relationshipEdgesAsA RelationshipEdge[] @relation("RelationshipEdgeCharacterA")
  relationshipEdgesAsB RelationshipEdge[] @relation("RelationshipEdgeCharacterB")

  @@index([projectId, name])
  @@index([projectId, source, scope], map: "Character_project_source_scope_idx")
}

model LorebookEntry {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @db.Uuid
  title            String   @db.VarChar(255)
  entryType        String   @db.VarChar(50)
  content          String
  summary          String?
  tags             Json     @default("[]")
  priority         Int      @default(50)
  triggerKeywords  Json     @default("[]")
  relatedEntityIds Json     @default("[]")
  status           String   @default("active") @db.VarChar(50)
  sourceType       String   @default("manual") @db.VarChar(50)
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, entryType])
  @@index([projectId, status], map: "LorebookEntry_project_status_idx")
}

model Chapter {
  id                String           @id @default(uuid()) @db.Uuid
  projectId         String           @db.Uuid
  volumeId          String?          @db.Uuid
  chapterNo         Int
  title             String?          @db.VarChar(255)
  objective         String?
  conflict          String?
  revealPoints      String?
  foreshadowPlan    String?
  outline           String?
  craftBrief        Json             @default("{}")
  status            ChapterStatus    @default(planned)
  expectedWordCount Int?
  actualWordCount   Int?
  timelineSeq       Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  volume            Volume?          @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  drafts            ChapterDraft[]
  storyEvents       StoryEvent[]
  characterStateSnapshots CharacterStateSnapshot[]
  foreshadowTracks  ForeshadowTrack[]
  timelineEvents    TimelineEvent[]
  sceneCards        SceneCard[]
  pacingBeats       PacingBeat[]
  validationIssues  ValidationIssue[]
  qualityReports    QualityReport[]
  generationJobs    GenerationJob[]

  @@unique([projectId, chapterNo])
}

model ChapterDraft {
  id                String   @id @default(uuid()) @db.Uuid
  chapterId         String   @db.Uuid
  versionNo         Int
  content           String
  source            String   @db.VarChar(50)
  modelInfo         Json     @default("{}")
  generationContext Json     @default("{}")
  isCurrent         Boolean  @default(false)
  createdBy         String?  @db.Uuid
  createdAt         DateTime @default(now())
  chapter           Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  qualityReports    QualityReport[]

  @@unique([chapterId, versionNo])
  @@index([chapterId, isCurrent, versionNo], map: "ChapterDraft_chapter_current_version_idx")
}

model MemoryChunk {
  id              String                @id @default(uuid()) @db.Uuid
  projectId       String                @db.Uuid
  sourceType      String                @db.VarChar(50)
  sourceId        String                @db.Uuid
  memoryType      String                @db.VarChar(50)
  content         String
  summary         String?
  embedding       Json?
  embeddingVector Unsupported("vector")?
  tags            Json                  @default("[]")
  sourceTrace     Json                  @default("{}")
  metadata        Json                  @default("{}")
  importanceScore Int                   @default(50)
  freshnessScore  Int                   @default(50)
  recencyScore    Int                   @default(50)
  status          String                @default("auto") @db.VarChar(50)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, memoryType, status])
  @@index([projectId, sourceType, sourceId])
  @@index([projectId, status], map: "MemoryChunk_project_status_idx")
  @@index([projectId, status, importanceScore, recencyScore, updatedAt], map: "MemoryChunk_project_status_rank_idx")
}

model StoryEvent {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  chapterId   String   @db.Uuid
  chapterNo   Int?
  sourceDraftId String? @db.Uuid
  title       String   @db.VarChar(255)
  eventType   String   @db.VarChar(50)
  description String
  participants Json    @default("[]")
  timelineSeq  Int?
  status      String   @default("detected") @db.VarChar(50)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId, chapterNo])
  @@index([projectId, eventType])
  @@index([projectId, chapterId, sourceDraftId], map: "StoryEvent_project_chapter_draft_idx")
}

model CharacterStateSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  chapterId    String   @db.Uuid
  chapterNo    Int?
  sourceDraftId String? @db.Uuid
  characterId  String?  @db.Uuid
  characterName String  @db.VarChar(100)
  stateType    String   @db.VarChar(50)
  stateValue   String
  summary      String?
  status       String   @default("auto") @db.VarChar(50)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter      Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId, characterName, chapterNo])
  @@index([projectId, status])
  @@index([projectId, chapterId, sourceDraftId], map: "CharacterStateSnapshot_project_chapter_draft_idx")
}

model ForeshadowTrack {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @db.Uuid
  chapterId        String?  @db.Uuid
  chapterNo        Int?
  sourceDraftId    String?  @db.Uuid
  title            String   @db.VarChar(255)
  detail           String?
  status           String   @default("planned") @db.VarChar(50)
  scope            String   @default("chapter") @db.VarChar(20) // "arc" | "volume" | "chapter"
  source           String   @default("manual") @db.VarChar(30)  // "guided" | "auto_extracted" | "manual"
  firstSeenChapterNo Int?
  lastSeenChapterNo  Int?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter          Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId, title])
  @@index([projectId, status])
  @@index([projectId, source], map: "ForeshadowTrack_project_source_idx")
  @@index([projectId, chapterId, sourceDraftId], map: "ForeshadowTrack_project_chapter_draft_idx")
}

model WritingRule {
  id                   String             @id @default(uuid()) @db.Uuid
  projectId            String             @db.Uuid
  ruleType             String             @db.VarChar(80)
  title                String             @db.VarChar(255)
  content              String
  severity             ValidationSeverity @default(info)
  appliesFromChapterNo Int?
  appliesToChapterNo   Int?
  entityType           String?            @db.VarChar(50)
  entityRef            String?            @db.VarChar(255)
  status               String             @default("active") @db.VarChar(50)
  metadata             Json               @default("{}")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  project              Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, ruleType, status], map: "WritingRule_project_ruleType_status_idx")
  @@index([projectId, severity, status], map: "WritingRule_project_severity_status_idx")
  @@index([projectId, entityType, entityRef], map: "WritingRule_project_entity_idx")
  @@index([projectId, appliesFromChapterNo, appliesToChapterNo], map: "WritingRule_project_chapter_range_idx")
}

model RelationshipEdge {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @db.Uuid
  characterAId     String?  @db.Uuid
  characterBId     String?  @db.Uuid
  characterAName   String   @db.VarChar(100)
  characterBName   String   @db.VarChar(100)
  relationType     String   @db.VarChar(80)
  publicState      String?
  hiddenState      String?
  conflictPoint    String?
  emotionalArc     String?
  turnChapterNos   Json     @default("[]")
  finalState       String?
  status           String   @default("active") @db.VarChar(50)
  sourceType       String   @default("manual") @db.VarChar(50)
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characterA       Character? @relation("RelationshipEdgeCharacterA", fields: [characterAId], references: [id], onDelete: SetNull)
  characterB       Character? @relation("RelationshipEdgeCharacterB", fields: [characterBId], references: [id], onDelete: SetNull)

  @@index([projectId, status, updatedAt], map: "RelationshipEdge_project_status_updated_idx")
  @@index([projectId, relationType, status], map: "RelationshipEdge_project_relation_status_idx")
  @@index([projectId, characterAName], map: "RelationshipEdge_project_characterAName_idx")
  @@index([projectId, characterBName], map: "RelationshipEdge_project_characterBName_idx")
  @@index([projectId, characterAId, characterBId], map: "RelationshipEdge_project_characterIds_idx")
}

model TimelineEvent {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  chapterId    String?  @db.Uuid
  chapterNo    Int?
  title        String   @db.VarChar(255)
  eventTime    String?  @db.VarChar(120)
  locationName String?  @db.VarChar(255)
  participants Json     @default("[]")
  cause        String?
  result       String?
  impactScope  String?  @db.VarChar(80)
  isPublic     Boolean  @default(false)
  knownBy      Json     @default("[]")
  unknownBy    Json     @default("[]")
  eventStatus  String   @default("active") @db.VarChar(50)
  sourceType   String   @default("manual") @db.VarChar(50)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter      Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([projectId, chapterNo, eventStatus], map: "TimelineEvent_project_chapter_status_idx")
  @@index([projectId, eventStatus, updatedAt], map: "TimelineEvent_project_status_updated_idx")
  @@index([projectId, eventTime], map: "TimelineEvent_project_eventTime_idx")
  @@index([projectId, chapterId], map: "TimelineEvent_project_chapterId_idx")
  @@index([projectId, locationName], map: "TimelineEvent_project_location_idx")
}

model SceneCard {
  id                    String   @id @default(uuid()) @db.Uuid
  projectId             String   @db.Uuid
  volumeId              String?  @db.Uuid
  chapterId             String?  @db.Uuid
  sceneNo               Int?
  title                 String   @db.VarChar(255)
  locationName          String?
  participants          Json     @default("[]")
  purpose               String?
  conflict              String?
  emotionalTone         String?
  keyInformation        String?
  result                String?
  relatedForeshadowIds  Json     @default("[]")
  status                String   @default("planned") @db.VarChar(50)
  metadata              Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  volume                Volume?  @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  chapter               Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([projectId, status, updatedAt], map: "SceneCard_project_status_updated_idx")
  @@index([projectId, volumeId, chapterId], map: "SceneCard_project_volume_chapter_idx")
  @@index([projectId, chapterId, sceneNo], map: "SceneCard_project_chapter_scene_idx")
  @@index([projectId, locationName], map: "SceneCard_project_location_idx")
  @@unique([chapterId, sceneNo], map: "SceneCard_chapter_sceneNo_key")
}

model ChapterPattern {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @db.Uuid
  patternType      String   @db.VarChar(80)
  name             String   @db.VarChar(255)
  applicableScenes Json     @default("[]")
  structure        Json     @default("{}")
  pacingAdvice     Json     @default("{}")
  emotionalAdvice  Json     @default("{}")
  conflictAdvice   Json     @default("{}")
  status           String   @default("active") @db.VarChar(50)
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status, updatedAt], map: "ChapterPattern_project_status_updated_idx")
  @@index([projectId, patternType, status], map: "ChapterPattern_project_pattern_status_idx")
}

model PacingBeat {
  id                 String   @id @default(uuid()) @db.Uuid
  projectId          String   @db.Uuid
  volumeId           String?  @db.Uuid
  chapterId          String?  @db.Uuid
  chapterNo          Int?
  beatType           String   @db.VarChar(80)
  emotionalTone      String?
  emotionalIntensity Int      @default(50)
  tensionLevel       Int      @default(50)
  payoffLevel        Int      @default(50)
  notes              String?
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  volume             Volume?  @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  chapter            Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([projectId, volumeId, chapterId], map: "PacingBeat_project_volume_chapter_idx")
  @@index([projectId, chapterNo], map: "PacingBeat_project_chapterNo_idx")
  @@index([projectId, beatType], map: "PacingBeat_project_beatType_idx")
}


model ValidationIssue {
  id          String              @id @default(uuid()) @db.Uuid
  projectId   String              @db.Uuid
  chapterId   String?             @db.Uuid
  issueType   String              @db.VarChar(100)
  severity    ValidationSeverity
  entityType  String?             @db.VarChar(50)
  entityId    String?             @db.Uuid
  message     String
  evidence    Json                @default("[]")
  suggestion  String?
  status      String              @default("open") @db.VarChar(50)
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter     Chapter?            @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([projectId, status, createdAt], map: "ValidationIssue_project_status_created_idx")
  @@index([chapterId, status, createdAt], map: "ValidationIssue_chapter_status_created_idx")
}

model QualityReport {
  id          String        @id @default(uuid()) @db.Uuid
  projectId   String        @db.Uuid
  chapterId   String?       @db.Uuid
  draftId     String?       @db.Uuid
  agentRunId  String?       @db.Uuid
  sourceType  String        @db.VarChar(50)
  sourceId    String?       @db.Uuid
  reportType  String        @db.VarChar(80)
  scores      Json          @default("{}")
  issues      Json          @default("[]")
  verdict     String        @db.VarChar(20)
  summary     String?
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter     Chapter?      @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  draft       ChapterDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)
  agentRun    AgentRun?     @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt], map: "QualityReport_project_created_idx")
  @@index([projectId, chapterId, createdAt], map: "QualityReport_project_chapter_created_idx")
  @@index([projectId, draftId], map: "QualityReport_project_draft_idx")
  @@index([projectId, agentRunId], map: "QualityReport_project_agentRun_idx")
  @@index([projectId, sourceType, reportType, verdict], map: "QualityReport_project_type_verdict_idx")
}

model GenerationJob {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @db.Uuid
  chapterId        String?   @db.Uuid
  jobType          String    @db.VarChar(50)
  targetType       String    @db.VarChar(50)
  targetId         String    @db.Uuid
  status           JobStatus @default(queued)
  requestPayload   Json      @default("{}")
  responsePayload  Json      @default("{}")
  retrievalPayload Json      @default("{}")
  promptSnapshot   String?
  errorMessage     String?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime  @default(now())
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter          Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([status, createdAt], map: "GenerationJob_status_created_idx")
  @@index([projectId, jobType, targetType, targetId, status, createdAt], map: "GenerationJob_active_lookup_idx")
}

model Volume {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  volumeNo     Int
  title        String?  @db.VarChar(255)
  synopsis     String?
  objective    String?
  narrativePlan Json    @default("{}")
  chapterCount Int?
  status       String   @default("planned") @db.VarChar(50)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapters     Chapter[]
  sceneCards   SceneCard[]
  pacingBeats  PacingBeat[]

  @@unique([projectId, volumeNo])
}

model PromptTemplate {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String?  @db.Uuid
  stepKey       String   @db.VarChar(50)
  name          String   @db.VarChar(100)
  description   String?
  systemPrompt  String
  userTemplate  String
  version       Int      @default(1)
  isDefault     Boolean  @default(false)
  tags          Json     @default("[]")
  effectPreview String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stepKey, name])
  @@index([stepKey, isDefault])
  @@index([projectId, stepKey, isDefault], map: "PromptTemplate_project_step_default_idx")
}

model GuidedSession {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  currentStep String   @db.VarChar(50)
  stepData    Json     @default("{}")
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId])
}

/// LLM 服务提供商配置（当前仅支持 OpenAI-Compatible 格式）
/// providerType 字段预留，未来可扩展 Claude/Gemini 等
model LlmProvider {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @db.VarChar(100)                        // 显示名称，如 "GPT-5.4 主力"
  providerType  String        @default("openai_compatible") @db.VarChar(50)
  baseUrl       String        @db.VarChar(500)                        // API base URL (e.g. https://api.openai.com/v1)
  apiKey        String        @db.Text                                // API Key（明文存储，与 .env 同级安全）
  defaultModel  String        @db.VarChar(200)                        // 默认模型名 (e.g. gpt-4o)
  extraConfig   Json          @default("{}")                          // 扩展配置（默认 temperature 等）
  isDefault     Boolean       @default(false)                         // 默认 Provider：步骤未配置路由时使用
  isActive      Boolean       @default(true)                          // 软停用标记
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  routings      LlmRouting[]
}

/// 应用步骤 → LLM Provider 路由映射
/// 固定 3 个步骤：guided（创作引导）、generate（章节生成）、polish（章节润色）
/// validation/fact_extractor/summary 等内部服务不走路由，直接用默认 Provider
model LlmRouting {
  id             String       @id @default(uuid()) @db.Uuid
  appStep        String       @unique @db.VarChar(50)                 // "guided" | "generate" | "polish"
  providerId     String       @db.Uuid
  modelOverride  String?      @db.VarChar(200)                        // 可选：覆盖 provider 的默认模型
  paramsOverride Json         @default("{}")                          // 可选：覆盖 temperature/maxTokens 等
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  provider       LlmProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
}
