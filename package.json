{
  "name": "novel-system",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev": "pnpm --parallel --filter web --filter api run dev",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:migrate": "pnpm --filter api exec prisma migrate deploy",
    "db:push": "pnpm --filter api exec prisma db push",
    "db:create": "python scripts/dev/create_database.py",
    "db:maintenance": "pnpm --dir apps/api run db:maintenance",
    "eval:agent:gate": "pnpm --dir apps/api run eval:agent:gate"
  }
}
