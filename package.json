{
  "name": "novel-system",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev": "pnpm --parallel --filter web --filter api run dev",
    "db:generate": "pnpm exec prisma generate --schema apps/api/prisma/schema.prisma",
    "db:migrate": "pnpm exec prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "db:push": "pnpm exec prisma db push --schema apps/api/prisma/schema.prisma",
    "db:create": "python scripts/dev/create_database.py",
    "db:maintenance": "pnpm --dir apps/api run db:maintenance",
    "eval:agent:gate": "pnpm --dir apps/api run eval:agent:gate"
  }
}
