DATABASE_NAME=ai_novel_mvp
# 如果数据库密码包含 &, ^ 等特殊字符，请先做 URL encode。
# 例如：P@ssw0rd&123 -> P%40ssw0rd%26123
DATABASE_URL=postgresql://postgres:ENCODED_PASSWORD@DB_HOST:5432/ai_novel_mvp
POSTGRES_ADMIN_URL=postgresql://postgres:ENCODED_PASSWORD@DB_HOST:5432/postgres
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_PROJECT_SNAPSHOT_TTL_SECONDS=300
CACHE_CHAPTER_CONTEXT_TTL_SECONDS=300
CACHE_RECALL_RESULT_TTL_SECONDS=120
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
API_PORT=3001
WEB_PORT=3000
LLM_BASE_URL=http://YOUR_LLM_HOST:8318/v1
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_MODEL=gpt-5.4
# Local/test default uses Agent Planner graph; set false to force legacy planner.
AGENT_PLANNER_GRAPH_ENABLED=true
EMBEDDING_BASE_URL=http://embedding/v1
EMBEDDING_PORT=18319
EMBEDDING_DIM=768
EMBEDDING_MODEL_PATH=/models/bge-base-zh-v1.5
# Local Compose embedding service usually does not need an API key.
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Xenova/bge-base-zh-v1.5

# DB maintenance script options (optional)
# LLM_PROVIDER_NAME=env_llm_primary
# DB_MAINTENANCE_PROJECT_ID=
# DB_MAINTENANCE_CHAPTER_ID=
# DB_MAINTENANCE_BACKFILL_BATCH_SIZE=16
# DB_MAINTENANCE_BACKFILL_MAX_CHUNKS=
# DB_MAINTENANCE_REEMBED_ALL_ON_DIM_MISMATCH=false
