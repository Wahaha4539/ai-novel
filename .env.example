DATABASE_NAME=ai_novel_mvp
# 如果数据库密码包含 &, ^ 等特殊字符，请先做 URL encode。
# 例如：P@ssw0rd&123 -> P%40ssw0rd%26123
DATABASE_URL=postgresql://postgres:ENCODED_PASSWORD@DB_HOST:5432/ai_novel_mvp
POSTGRES_ADMIN_URL=postgresql://postgres:ENCODED_PASSWORD@DB_HOST:5432/postgres
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
API_PORT=3001
WEB_PORT=3000
WORKER_PORT=8000
WORKER_BASE_URL=http://localhost:8000
LLM_BASE_URL=http://YOUR_LLM_HOST:8318/v1
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_MODEL=gpt-5.4
